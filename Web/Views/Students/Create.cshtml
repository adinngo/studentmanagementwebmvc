@model Web.Models.Student.StudentViewModel
@{
    ViewData["Title"] = "Create";
}


<div class="container mt-4 custom-max-width">
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-4">Create Student</h4>
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-action="Create" method="post">
                
                <div class="mb-3">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Enter last name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FirstMidName" class="form-label"></label>
                    <input asp-for="FirstMidName" class="form-control" placeholder="Enter first name" />
                    <span asp-validation-for="FirstMidName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EnrollmentDate" class="form-label"></label>
                    <input asp-for="EnrollmentDate" type="date" class="form-control" />
                    <span asp-validation-for="EnrollmentDate" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>

            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}