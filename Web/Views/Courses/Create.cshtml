@model Web.Models.Course.CourseViewModel
@{
    ViewData["Title"] = "Create Course";
}


<h2 class="text-center">Create Course</h2>

<div class="container mt-4 custom-max-width">
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-4">Create Student</h4>
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-action="Create" method="post">
                
                <div class="form-group mb-3">
                    <label asp-for="@Model.CourseID" class="form-label"></label>
                    <input asp-for="@Model.CourseID" class="form-control" placeholder="Enter CourseID [1000, 5000]" />
                    <span asp-validation-for="@Model.CourseID" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="@Model.Title" class="form-label"></label>
                    <input asp-for="@Model.Title" class="form-control" placeholder="Enter Title" />
                    <span asp-validation-for="@Model.Title" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="@Model.Credits" class="form-label"></label>
                    <input asp-for="@Model.Credits" class="form-control" placeholder="Enter Credits [1, 5]" />
                    <span asp-validation-for="@Model.Credits" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DepartmentID" class="control-label">Department</label>
                    <select asp-for="DepartmentID" class="form-control" asp-items="ViewBag.DepartmentID">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentID" class="text-danger" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>

            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}