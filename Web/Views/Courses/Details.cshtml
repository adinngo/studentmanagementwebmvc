@model Web.Models.Course.CourseViewModel
@{
    ViewData["Title"] = "Course Details";
}



<dl class="row">
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.CourseID)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.CourseID)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Title)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Title)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Credits)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Credits)
    </dd>
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Department)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Department)
    </dd>
</dl>
<dl class="row">
    <dt class="col-sm-2">
        Course Assignments
    </dt>
    <dd class="col-sm-8">
        <table class="table">
            <tr>
                <th>Instructors</th> 
            </tr>
            @foreach (var item in Model.CourseAssignmentsVM!)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.InstructorFullName)
                    </td>
                   
                </tr>
            }
        </table>
    </dd>
</dl>
<dl class="row">
    <dt class="col-sm-2">
        Enrollments
    </dt>
    <dd class="col-sm-8">
        <table class="table">
            <tr>
                <th>Student</th>
            </tr>
            @foreach (var item in Model.EnrollmentViewModels!)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.StudentFullName)
                    </td>
                   
                </tr>
            }
        </table>
    </dd>
</dl>
<div>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
