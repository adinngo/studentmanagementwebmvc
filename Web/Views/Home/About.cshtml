@model IEnumerable<Web.Models.About.EnrollmentDateGroup>

@{
    ViewData["Title"] = "Student Body Statistics";
}
<h2>Student Body Statistics</h2>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(modelItem => modelItem.EnrollmentDate)</th>
            <th> @Html.DisplayNameFor(modelItem => modelItem.StudentCount)</th>
        </tr>
    </thead>
    <tbody>
        
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.EnrollmentDate)</td>
                <td>@item.StudentCount</td>
            </tr>
        }
        
    </tbody>
</table>